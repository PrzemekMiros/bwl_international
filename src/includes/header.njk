<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ menu.project }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@200..700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/styles.css" />
  </head>
  <body class="min-h-screen text-slate-100">
    <header class="bg-[#f1f1f1] text-slate-900">
      <div class="mx-auto max-w-[1200px] px-4">
        <div class="grid min-h-[84px] grid-cols-[1fr_auto_1fr] items-center py-4 md:h-[108px] md:py-0">
          <div></div>
            <div class="hidden leading-none sm:block">
               <a href="/">
                <img src="/assets/img/logo/logo.png">
               </a>
            </div>
          <div class="flex items-center justify-end gap-3 pr-1 sm:gap-4 sm:pr-3">
            <a href="#" aria-label="Facebook" class="text-[#232323] hover:text-black">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M13.5 21v-8h2.7l.4-3h-3.1V8.1c0-.9.3-1.5 1.6-1.5h1.7V4c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.4-4 4.1V10H8v3h2.4v8h3.1z"/>
              </svg>
            </a>
            <a href="#" aria-label="Instagram" class="text-[#232323] hover:text-black">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
                <circle cx="12" cy="12" r="4"></circle>
                <circle cx="17.2" cy="6.8" r="1"></circle>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <div class="bg-[#171717] shadow-[inset_0_1px_0_rgba(255,255,255,0.07)]">
        <div class="mx-auto max-w-[1200px] px-0">
          <nav class="relative">
            <ul class="flex items-stretch overflow-x-auto whitespace-nowrap">
              {% for item in menu.navigation_main %}
                <li class="{% if loop.first %}border-l-4 border-l-[#c59b52]{% endif %}">
                  <a
                    href="{{ item.url }}"
                    class="flex h-[52px] items-center px-4 text-[13px] font-medium uppercase tracking-[0.06em] text-white transition hover:bg-[#303030] sm:h-[82px] sm:px-8 sm:text-[14px] {% if loop.first %}bg-[#232323]{% endif %}"
                  >
                    {{ item.label }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </nav>
        </div>
      </div>
      <div class="h-[2px] w-full bg-[#111f72]"></div>
    </header>
