---
layout: base.njk
title: Wywiady
description: Archiwum wywiadow
permalink: /wywiady/
---

<section class="mx-auto max-w-[1200px] py-16">
  <div class="mb-8">
    <p class="text-sm uppercase tracking-[0.2em] text-[#d4ab71]">Typ postu</p>
    <h1 class="mt-2 text-3xl font-semibold uppercase tracking-[0.04em] text-[#0b0d1e]">Wywiady</h1>
  </div>

  {% set interviews = collections.wywiadyCollection %}
  {% if interviews %}
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {% for interview in interviews %}
        <article class="rounded-2xl border border-black/10 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-[#0b0d1e]">
            <a href="{{ interview.url }}" class="transition-colors hover:text-[#d4ab71]">{{ interview.data.title }}</a>
          </h2>
          {% if interview.data.person %}
            <p class="mt-2 text-sm uppercase tracking-[0.08em] text-black/60">{{ interview.data.person }}</p>
          {% endif %}
          {% if interview.data.excerpt %}
            <p class="mt-4 text-sm leading-6 text-black/80">{{ interview.data.excerpt }}</p>
          {% endif %}
          <a class="mt-5 inline-block text-sm font-semibold uppercase tracking-[0.08em] text-[#0b0d1e] hover:text-[#d4ab71]" href="{{ interview.url }}">
            Czytaj wywiad
          </a>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-black/70">Brak opublikowanych wywiadow.</p>
  {% endif %}
</section>
